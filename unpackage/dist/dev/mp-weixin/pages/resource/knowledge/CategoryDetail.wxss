
/* 页面容器 */
.page-container.data-v-73d5eed3 {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f5f7fa;
}

/* 顶部导航栏 */
.nav-bar.data-v-73d5eed3 {
  background-color: #2563eb; /* 医疗蓝 */
  padding-top: var(--status-bar-height);
}
.nav-content.data-v-73d5eed3 {
  height: 44px;
  display: flex;
  align-items: center;
  padding: 0 16px;
}
.back-icon.data-v-73d5eed3 {
  margin-right: 12px;
}
.nav-title.data-v-73d5eed3 {
  color: #ffffff;
  font-size: 18px;
  font-weight: bold;
}

/* 滚动内容区 */
.content-scroll.data-v-73d5eed3 {
  flex: 1;
  overflow-y: auto;
}
.p-4.data-v-73d5eed3 {
  padding: 16px;
}
.section-title.data-v-73d5eed3 {
  display: block;
  font-size: 16px;
  font-weight: bold;
  color: #1f2937;
  margin-bottom: 16px;
}

/* 加载状态 */
.loading-state.data-v-73d5eed3 {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40px 0;
}
.loading-text.data-v-73d5eed3 {
  margin-top: 8px;
  font-size: 14px;
  color: #6b7280;
}

/* 病种列表 */
.disease-list.data-v-73d5eed3 {
  display: flex;
  flex-direction: column;
}
.disease-card.data-v-73d5eed3 {
  background-color: #ffffff;
  padding: 16px;
  border-radius: 8px;
  margin-bottom: 12px;
  box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
  border: 1px solid #e5e7eb;
}
.disease-card.data-v-73d5eed3:last-child {
  margin-bottom: 0;
}
.disease-name.data-v-73d5eed3 {
  display: block;
  font-size: 16px;
  font-weight: 600;
  color: #1d4ed8;
  margin-bottom: 8px;
}
.disease-intro.data-v-73d5eed3 {
  display: block;
  font-size: 14px;
  color: #6b7280;
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

/* 空状态 */
.empty-state.data-v-73d5eed3 {
  padding: 40px 0;
}
