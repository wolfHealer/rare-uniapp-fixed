
/* 页面容器 */
.page-container.data-v-b7c6fc8a {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f9fafb;
}

/* 搜索栏 */
.search-bar.data-v-b7c6fc8a {
  position: -webkit-sticky;
  position: sticky;
  top: 0;
  z-index: 10;
  background-color: #ffffff;
  padding: 16px;
  box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
}

/* 内容滚动区 */
.content-scroll.data-v-b7c6fc8a {
  flex: 1;
  /* overflow-y: auto;  scroll-view 不需要这个，它自己处理滚动 */
}
.section-container.data-v-b7c6fc8a {
  padding: 16px;
  /* 确保不会阻挡点击 */
  position: relative; 
  z-index: 1;
}
.section-title.data-v-b7c6fc8a {
  display: block;
  font-size: 18px;
  font-weight: bold;
  color: #1f2937;
  margin-bottom: 16px;
  padding-left: 4px;
}

/* ⭐ 推荐入口样式 */
.recommend-section.data-v-b7c6fc8a {
  padding-bottom: 8px;
}
.recommend-grid.data-v-b7c6fc8a {
  display: flex;
  gap: 16px;
}
.recommend-item.data-v-b7c6fc8a {
  flex: 1;
  background: #fff;
  border-radius: 12px;
  padding: 16px;
  display: flex;
  align-items: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.03);
  /* 确保可点击 */
  cursor: pointer;
}
.rec-icon-bg.data-v-b7c6fc8a {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
  margin-right: 12px;
}
.rec-icon-bg.blue.data-v-b7c6fc8a { background-color: #eff6ff;
}
.rec-icon-bg.orange.data-v-b7c6fc8a { background-color: #fff7ed;
}
.rec-title.data-v-b7c6fc8a {
  font-size: 15px;
  font-weight: 600;
  color: #374151;
}

/* 🧩 12类分类宫格样式 (重点) */
.category-grid.data-v-b7c6fc8a {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16px;
}
.category-card.data-v-b7c6fc8a {
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.03);
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  border: 1px solid #f3f4f6;
  /* 关键：确保点击事件能穿透到 view */
  position: relative;
  z-index: 2;
}
.category-card-hover.data-v-b7c6fc8a {
  background-color: #f9fafb;
  transform: scale(0.98);
  transition: all 0.2s;
}
.icon-circle.data-v-b7c6fc8a {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}
.category-emoji.data-v-b7c6fc8a {
  font-size: 40rpx;
}
.category-name.data-v-b7c6fc8a {
  font-size: 30rpx;
  font-weight: bold;
  color: #1f2937;
  margin-bottom: 8rpx;
}
.category-desc.data-v-b7c6fc8a {
  font-size: 22rpx;
  color: #9ca3af;
  line-height: 1.4;
}

/* 底部 Banner */
.bottom-banner.data-v-b7c6fc8a {
  padding: 0 16px 16px;
}
.banner-content.data-v-b7c6fc8a {
  background-color: #f0fdf4;
  border: 1px solid #dcfce7;
  border-radius: 8px;
  padding: 12px;
  text-align: center;
}
.banner-text.data-v-b7c6fc8a {
  font-size: 12px;
  color: #166534;
}

/* 底部占位 */
.bottom-placeholder.data-v-b7c6fc8a {
  height: 64px;
}
