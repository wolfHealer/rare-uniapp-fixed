
.page-container.data-v-5f1e9c4b {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f9fafb;
}
.filter-area.data-v-5f1e9c4b {
  flex-shrink: 0;
  background: #fff;
  padding: 12px 16px;
  border-bottom: 1px solid #f3f4f6;
  z-index: 10;
}
.loading-state.data-v-5f1e9c4b {
  padding: 32px 0;
  display: flex;
  justify-content: center;
  align-items: center;
}
.loading-text.data-v-5f1e9c4b {
  margin-left: 8px;
  font-size: 14px;
  color: #6b7280;
}
.empty-state.data-v-5f1e9c4b {
  padding: 32px 0;
  text-align: center;
}
.content-scroll.data-v-5f1e9c4b {
  flex: 1;
  overflow-y: auto;
}
.project-list.data-v-5f1e9c4b {
  padding: 16px;
  display: flex;
  flex-direction: column;
  gap: 12px;
}
.project-card.data-v-5f1e9c4b {
  background-color: #ffffff;
  border-radius: 12px;
  padding: 16px;
  box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
  /* 增加点击态反馈 */
  transition: background-color 0.2s;
}
.project-card.data-v-5f1e9c4b:active {
  background-color: #f3f4f6;
}
.project-name.data-v-5f1e9c4b {
  font-weight: 600;
  font-size: 16px;
  display: block;
  color: #1f2937;
}
.project-meta.data-v-5f1e9c4b {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-top: 8px;
}
.organizer-text.data-v-5f1e9c4b {
  font-size: 12px;
  color: #6b7280;
}
.project-info.data-v-5f1e9c4b {
  font-size: 14px;
  color: #6b7280;
  display: block;
  margin-top: 8px;
}
.project-desc.data-v-5f1e9c4b {
  font-size: 14px;
  color: #374151;
  display: block;
  margin-top: 4px;
}
.status-row.data-v-5f1e9c4b {
  margin-top: 12px;
  display: flex;
  align-items: center;
}
.deadline-text.data-v-5f1e9c4b {
  font-size: 12px;
  color: #9ca3af;
  margin-left: 8px;
}

/* 新增：点击提示样式 */
.click-hint.data-v-5f1e9c4b {
  margin-top: 12px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 12px;
  color: #9ca3af;
}
