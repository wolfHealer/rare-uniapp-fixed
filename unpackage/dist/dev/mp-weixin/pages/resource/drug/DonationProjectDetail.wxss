
/* 页面容器 */
.page-container.data-v-11202550 {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f9fafb;
}

/* 顶部导航 */
.nav-bar.data-v-11202550 {
  position: -webkit-sticky;
  position: sticky;
  top: 0;
  z-index: 10;
  background-color: #ffffff;
  padding: 16px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
}
.nav-title.data-v-11202550 {
  font-size: 18px;
  font-weight: bold;
}
.nav-placeholder.data-v-11202550 {
  width: 24px;
}

/* 加载状态 */
.loading-state.data-v-11202550 {
  margin-top: 32px;
  display: flex;
  justify-content: center;
  align-items: center;
}
.loading-text.data-v-11202550 {
  margin-left: 8px;
  font-size: 14px;
  color: #6b7280;
}

/* 滚动内容 */
.content-scroll.data-v-11202550 {
  flex: 1;
  overflow-y: auto;
}

/* 卡片样式 */
.card.data-v-11202550 {
  background-color: #ffffff;
  padding: 16px;
  margin-top: 12px;
}
.project-name.data-v-11202550 {
  font-size: 20px;
  font-weight: bold;
  display: block;
  margin-bottom: 8px;
  color: #1f2937;
}
.tags-row.data-v-11202550 {
  display: flex;
  gap: 8px;
  margin-top: 8px;
}
.info-list.data-v-11202550 {
  margin-top: 12px;
  font-size: 14px;
}
.info-item.data-v-11202550 {
  display: flex;
  justify-content: space-between;
  padding: 8px 0;
  border-bottom: 1px solid #e5e7eb;
}
.info-item.no-border.data-v-11202550 {
  border-bottom: none;
}
.info-label.data-v-11202550 {
  color: #6b7280;
}
.info-value.data-v-11202550 {
  color: #374151;
  font-weight: 500;
}
.section-header.data-v-11202550 {
  font-weight: 600;
  font-size: 16px;
  display: block;
  margin-bottom: 8px;
  color: #1f2937;
}
.section-content.data-v-11202550 {
  font-size: 14px;
  color: #374151;
  line-height: 1.6;
  white-space: pre-line;
  display: block;
}
.service-time.data-v-11202550 {
  display: flex;
  align-items: center;
  font-size: 14px;
  color: #374151;
}
.time-icon.data-v-11202550 {
  margin-right: 4px;
  color: #6b7280;
}

/* 资源列表 */
.resource-list.data-v-11202550 {
  display: flex;
  flex-direction: column;
}

/* 底部操作栏 */
.action-bar.data-v-11202550 {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #ffffff;
  padding: 12px 16px;
  box-shadow: 0 -1px 2px rgba(0, 0, 0, 0.05);
  display: flex;
  align-items: center;
  z-index: 20;
}
.bottom-safe-area.data-v-11202550 {
  height: 80px; /* 为底部固定按钮留出空间 */
}

/* 空状态 */
.empty-state.data-v-11202550 {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}
