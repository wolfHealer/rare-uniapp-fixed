
.page-container.data-v-de57bc56 {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f9fafb;
}
.nav-bar.data-v-de57bc56 {
  position: -webkit-sticky;
  position: sticky;
  top: 0;
  z-index: 10;
  background-color: #ffffff;
  padding: 16px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
}
.nav-title.data-v-de57bc56 {
  font-size: 18px;
  font-weight: bold;
}
.nav-placeholder.data-v-de57bc56 {
  width: 24px;
}
.loading-state.data-v-de57bc56 {
  margin-top: 32px;
  display: flex;
  justify-content: center;
  align-items: center;
}
.loading-text.data-v-de57bc56 {
  margin-left: 8px;
  font-size: 14px;
  color: #6b7280;
}
.content-scroll.data-v-de57bc56 {
  flex: 1;
  overflow-y: auto;
}
.card.data-v-de57bc56 {
  background-color: #ffffff;
  padding: 16px;
  margin-top: 12px;
}
.channel-name.data-v-de57bc56 {
  font-size: 20px;
  font-weight: bold;
  display: block;
  margin-bottom: 8px;
}
.tags-row.data-v-de57bc56 {
  display: flex;
  gap: 8px;
  margin-top: 8px;
}
.info-list.data-v-de57bc56 {
  margin-top: 12px;
  font-size: 14px;
}
.info-item.data-v-de57bc56 {
  display: flex;
  justify-content: space-between;
  padding: 8px 0;
  border-bottom: 1px solid #e5e7eb;
}
.info-item.no-border.data-v-de57bc56 {
  border-bottom: none;
}
.info-label.data-v-de57bc56 {
  color: #6b7280;
}
.info-value.data-v-de57bc56 {
  color: #374151;
}
.section-header.data-v-de57bc56 {
  font-weight: 600;
  font-size: 16px;
  display: block;
  margin-bottom: 8px;
  color: #1f2937;
}
.section-content.data-v-de57bc56 {
  font-size: 14px;
  color: #374151;
  line-height: 1.6;
  display: block;
}

