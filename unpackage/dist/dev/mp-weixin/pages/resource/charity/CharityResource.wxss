
.page-container.data-v-3059dcad {
  min-height: 100vh;
  background-color: #f9fafb;
  display: flex;
  flex-direction: column;
}

/* 自定义顶部栏 */
.custom-header.data-v-3059dcad {
  background-color: #1E90FF; /* 深天蓝色，与 DrugResource 保持一致 */
  padding: 16px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: white;
}
.header-title.data-v-3059dcad {
  font-size: 18px;
  font-weight: bold;
  color: #FFFFFF;
}
.header-placeholder.data-v-3059dcad {
  width: 24px; /* 占位，使标题居中 */
}

/* Tabs 包装器 */
.tabs-wrapper.data-v-3059dcad {
  background-color: #ffffff;
  position: -webkit-sticky;
  position: sticky;
  top: 0;
  z-index: 99;
}

/* 内容滚动区域 */
.content-scroll.data-v-3059dcad {
  flex: 1;
  height: 0; /* 配合 flex: 1 使用，确保 scroll-view 正确计算高度 */
  overflow-y: auto;
}
.tab-content.data-v-3059dcad {
  min-height: 100%;
}
