
/* 页面容器 */
.page-container.data-v-7b33b8a4 {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f9fafb;
}

/* 顶部导航 */
.nav-bar.data-v-7b33b8a4 {
  position: -webkit-sticky;
  position: sticky;
  top: 0;
  z-index: 10;
  background-color: #ffffff;
  padding: 16px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
}
.nav-title.data-v-7b33b8a4 {
  font-size: 18px;
  font-weight: bold;
}
.nav-placeholder.data-v-7b33b8a4 {
  width: 24px;
}

/* 加载状态 */
.loading-state.data-v-7b33b8a4 {
  margin-top: 32px;
  display: flex;
  justify-content: center;
  align-items: center;
}
.loading-text.data-v-7b33b8a4 {
  margin-left: 8px;
  font-size: 14px;
  color: #6b7280;
}

/* 滚动内容 */
.content-scroll.data-v-7b33b8a4 {
  flex: 1;
  overflow-y: auto;
}

/* 卡片样式 */
.card.data-v-7b33b8a4 {
  background-color: #ffffff;
  padding: 16px;
  margin-top: 12px;
}
.channel-name.data-v-7b33b8a4 {
  font-size: 20px;
  font-weight: bold;
  display: block;
  margin-bottom: 8px;
}
.tags-row.data-v-7b33b8a4 {
  display: flex;
  gap: 8px;
  margin-top: 8px;
}
.section-header.data-v-7b33b8a4 {
  font-weight: 600;
  font-size: 16px;
  display: block;
  margin-bottom: 8px;
  color: #1f2937;
}
.warning-header.data-v-7b33b8a4 {
  color: #ea580c;
}
.contact-info.data-v-7b33b8a4 {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 8px 0;
  border-bottom: 1px solid #e5e7eb;
  font-size: 14px;
  color: #374151;
}
.contact-icon.data-v-7b33b8a4 {
  margin-right: 4px;
}
.link-text.data-v-7b33b8a4 {
  word-break: break-all;
  color: #2563eb;
}
.action-buttons.data-v-7b33b8a4 {
  display: flex;
  gap: 8px;
  margin-top: 12px;
}
.service-time.data-v-7b33b8a4 {
  display: flex;
  align-items: center;
  font-size: 14px;
  color: #374151;
}
.time-icon.data-v-7b33b8a4 {
  margin-right: 4px;
}
.section-content.data-v-7b33b8a4 {
  font-size: 14px;
  color: #374151;
  line-height: 1.6;
  white-space: pre-line;
  display: block;
}
.warning-content.data-v-7b33b8a4 {
  color: #c2410c;
}

/* 资源列表 */
.resource-list.data-v-7b33b8a4 {
  display: flex;
  flex-direction: column;
}

/* 底部操作区 */
.action-card.data-v-7b33b8a4 {
  margin-bottom: 0;
}
.bottom-safe-area.data-v-7b33b8a4 {
  height: 20px;
}

/* 空状态 */
.empty-state.data-v-7b33b8a4 {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}
